# ── Application ──────────────────────────────────────────────────────────────
API_PORT=8080

# ── Database Connection ───────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=exporter
DB_PASSWORD=secret
DB_NAME=exports_db
DATABASE_URL=postgresql://exporter:secret@db:5432/exports_db

# ── Export Storage ────────────────────────────────────────────────────────────
# Directory where temporary CSV export files are written
EXPORT_STORAGE_PATH=/app/exports

# ── Redis Connection ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Streaming Tuning ─────────────────────────────────────────────────────────
# Number of rows fetched per cursor batch (tune for memory vs throughput)
DB_CURSOR_BATCH_SIZE=1000
